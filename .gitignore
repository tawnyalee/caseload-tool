.venv/
browser_data/
screenshots/
.env
__pycache__/
*.pyc
.pytest_cache/
.playwright/
.idea/
.vscode/
.claude/
build/
dist/
dist-nuitka/
*.spec.bak

# Real student data captured during inspection — FERPA, don't commit.
# Ignore the folder's CONTENTS (HTML/PNG snapshots) but keep the two shipped
# app assets. (Must be `resources/*` not `resources/` so the negations apply —
# git can't re-include a file inside a wholly-excluded directory.)
resources/*
!resources/app.ico
!resources/splash.gif

# Nuitka intermediates
*.build/
*.dist/
*.onefile-build/

# Release archives — distribute via GitHub Releases, not the repo.
CaseloadNotes-*.zip

# Per-user session log (created at runtime in dev mode).
note_log.csv

# Local data-at-rest encryption (src/crypto_store.py). vault.json holds the
# password salt + verifier + DPAPI-sealed key; *.enc are the encrypted student
# data files; *.tmp is atomic-write scratch. Never commit any of these.
vault.json
*.enc
*.tmp

# Diagnostic reports from the 'griddiff:' / 'gridbuild:' keywords — hold student
# values (PII).
griddiff_report.txt
gridbuild_report.txt
gridschema_report.txt

# Cached caseload export — student PII, FERPA, never commit.
caseload.csv
# Backups/temp written by the download anti-clobber guard (also PII).
caseload.csv.*
# Local caseload history snapshots — student PII, FERPA, never commit
# (covers history.db and any -journal/-wal/-shm sidecars + CSV exports).
history.db*
caseload_history.csv
# Local per-student Success Path state (field values + step log) — PII, FERPA.
success_path.db*
# Mongoose contacts/segment exports (Contact ids + names + mobiles) — PII.
# These can be named anything (e.g. "all C769 students-cfad.csv"), so the
# narrow patterns below aren't enough on their own.
mongoose*.csv
*segment*.csv
*contacts*.csv
# CATCH-ALL: the config dir IS the repo root in dev, where every CSV export
# (caseload + Mongoose segments) lands. Treat ALL root-level CSVs as local PII
# and never commit them. Use `git add -f` for the rare CSV meant to be tracked.
/*.csv
# Single-instance lock file (runtime).
launcher.lock

# The user's live scenarios (their personal batches/scenarios/emails).
# Only the bundled sample, default_scenarios.yaml, is tracked. The legacy
# notes.yaml name + its backups are ignored too.
scenarios.yaml
scenarios.yaml.bak
scenarios-*.yaml
notes.yaml
notes.yaml.bak*

# Browser-preview temp written by the HTML editor's Preview button.
_preview.html

# Per-user settings (advanced mode, first-run flag, etc.) — local
# to each install; don't commit.
settings.json

# User-specific email templates — the user's live folder(s). Only the
# bundled sample set (default_email_templates/) ships with the repo.
# Real students' emails contain identifiable correspondence; keep them
# out of source control (FERPA). "templates/" is the legacy folder name.
email_templates/
templates/

# Network-capture dumps from the 🔬 Capture button. Contain
# Salesforce session cookies + aura.token (active credentials)
# AND student PII inside the request bodies. Never commit.
capture-*.json

# Dev DOM dumps + scratch dir used while reverse-engineering the
# Salesforce notes DOM. Contain student PII; never commit.
dom_dump.html
temp/

# Inline-edit / task-unlock diagnostic dumps written at runtime to debug
# Salesforce commit failures. Contain captured DOM (may include PII); the app
# writes them under USER_CONFIG_DIR — a repo-root copy is a stale artifact.
flup_probe.txt
unlock_probe.txt
aura_probe.txt
ea_feed_probe.txt
